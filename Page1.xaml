<Page x:Class="PR4_Test.Page1"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:PR4_Test"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Page1">

    <Grid Background="#FFC5FDCA">
        <TextBlock HorizontalAlignment="Center" Margin="0,10,0,0" TextWrapping="Wrap" VerticalAlignment="Top" FontSize="24"><Run Language="ru-ru" Text="Вариант 8"/></TextBlock>
        <Image Margin="231,63,252,294" Source="/Images/1.png" Stretch="Fill"/>
        <TextBlock HorizontalAlignment="Left" Margin="235,196,0,0" TextWrapping="Wrap" Text="x" VerticalAlignment="Top" FontSize="16"/>
        <TextBlock HorizontalAlignment="Left" Margin="231,240,0,0" TextWrapping="Wrap" Text="y" VerticalAlignment="Top" FontSize="16"/>
        <TextBlock HorizontalAlignment="Left" Margin="231,295,0,0" TextWrapping="Wrap" Text="z" VerticalAlignment="Top" RenderTransformOrigin="-0.166,-0.305" FontSize="16"/>
        <Button x:Name="btnCalculate" Content="Вычислить" HorizontalAlignment="Left" Margin="269,391,0,0" VerticalAlignment="Top" Click="BtnCalculate_Click" FontSize="16" Height="34" Width="101" Background="#FFD66868"/>
        <Button x:Name="btnClear" Content="Очистить" HorizontalAlignment="Left" Margin="400,391,0,0" VerticalAlignment="Top" RenderTransformOrigin="-0.129,-0.122" FontSize="16" Height="33" Width="99" Click="BtnClear_Click" Background="#FFD66868"/>
        <Button x:Name="btnNext" Content="Далее" HorizontalAlignment="Left" Margin="659,391,0,0" VerticalAlignment="Top" RenderTransformOrigin="-0.129,-0.122" FontSize="16" Height="28" Width="89" Click="BtnNext_Click" Background="#FFD66868"/>
        <TextBox x:Name="txtX" HorizontalAlignment="Left" Margin="269,194,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="102" Height="26"/>
        <TextBox x:Name="txtZ" HorizontalAlignment="Left" Margin="269,295,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="102" Height="26"/>
        <TextBox x:Name="txtY" HorizontalAlignment="Left" Margin="269,240,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="102" Height="26"/>
        <TextBlock HorizontalAlignment="Left" Margin="209,340,0,0" TextWrapping="Wrap" VerticalAlignment="Top" FontSize="16" Height="27" Width="51" RenderTransformOrigin="0.523,1.267"><Run Language="ru-ru" Text="Ответ"/></TextBlock>
        <TextBox x:Name="txtResult" HorizontalAlignment="Left" Margin="269,340,0,0" TextWrapping="Wrap" Text="0" VerticalAlignment="Top" Width="102" Height="26"/>

    </Grid>
</Page>
