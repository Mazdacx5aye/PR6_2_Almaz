<Page x:Class="PR4_Test.Page2"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:PR4_Test"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Page2">

    <Grid Background="#FF83A1C6">
        <TextBlock HorizontalAlignment="Center" Margin="0,10,0,0" TextWrapping="Wrap" VerticalAlignment="Top" FontSize="24"><Run Language="ru-ru" Text="Вариант 8"/></TextBlock>
        <Image Margin="262,59,262,321" Source="/Images/2.png" Stretch="Fill"/>
        <TextBlock HorizontalAlignment="Left" Margin="280,161,0,0" TextWrapping="Wrap" Text="x" VerticalAlignment="Top" FontSize="16"/>
        <TextBlock HorizontalAlignment="Left" Margin="277,208,0,0" TextWrapping="Wrap" Text="m" VerticalAlignment="Top" FontSize="16" RenderTransformOrigin="3.814,0.886" Height="22" Width="24"/>
        <TextBox x:Name="txtX" HorizontalAlignment="Left" Margin="310,159,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="102" Height="26"/>
        <TextBox x:Name="txtM" HorizontalAlignment="Left" Margin="310,208,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="102" Height="26"/>
        <RadioButton x:Name="rbtnSh" Content="sh(x)" HorizontalAlignment="Left" Margin="310,251,0,0" VerticalAlignment="Top"/>
        <RadioButton x:Name="rbtnX2" Content="x^2" HorizontalAlignment="Left" Margin="310,282,0,0" VerticalAlignment="Top"/>
        <RadioButton x:Name="rbtnExp" Content="e^x" HorizontalAlignment="Left" Margin="310,313,0,0" VerticalAlignment="Top"/>
        <Button x:Name="btnCalculate" Content="Вычислить" HorizontalAlignment="Left" Margin="308,386,0,0" VerticalAlignment="Top" FontSize="16" Height="33" Width="106" Click="btnCalculate_Click" Background="#FF82CF92"/>
        <Button x:Name="btnClear" Content="Очистить" HorizontalAlignment="Left" Margin="441,388,0,0" VerticalAlignment="Top" RenderTransformOrigin="-0.129,-0.122" FontSize="16" Height="31" Width="106" Click="btnClear_Click" Background="#FF82CF92"/>
        <TextBlock HorizontalAlignment="Left" Margin="258,347,0,0" TextWrapping="Wrap" VerticalAlignment="Top" FontSize="16" Height="27" Width="51" RenderTransformOrigin="0.523,1.267"><Run Language="ru-ru" Text="Ответ"/></TextBlock>
        <Button x:Name="btnNext" Content="Далее" HorizontalAlignment="Left" Margin="659,391,0,0" VerticalAlignment="Top" RenderTransformOrigin="-0.129,-0.122" FontSize="16" Height="28" Width="89" Click="BtnNext_Click" Background="#FF82CF92"/>
        <TextBox x:Name="txtResult" HorizontalAlignment="Left" Margin="310,348,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="102" Height="26"/>
    </Grid>
</Page>
